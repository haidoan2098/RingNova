%%{ init: { 'theme': 'dark' } }%%
flowchart TD
    subgraph POWER["Power-on"]
        A["BBB cap nguon"]
    end

    subgraph ROM["ROM Code (AM335x SoC)"]
        B["Reset vector - ROM internal"]
        C["Detect boot device<br/>(SD card / eMMC / UART)"]
        D["Read MLO from SD sector 0<br/>copy to SRAM @ 0x402F0400"]
        E["Jump to 0x402F0400"]
    end

    subgraph SPL["SPL - boot/spl/ (SRAM)"]
        F["_start (start.S)<br/>mask IRQ, setup stacks,<br/>disable WDT1, set VBAR"]
        G["bootloader_main()"]
        H["UART init - debug output"]
        I["clock_init() - DDR PLL 400MHz"]
        J["ddr_init() + ddr_test()"]
        K["mmc_init() + load kernel.bin<br/>to DDR @ 0x80000000"]
        L["r0=0, r1=0x0E05, r2=0<br/>ldr pc, =0x80000000"]
    end

    subgraph KERNEL["Kernel - boot/kernel/ (DDR)"]
        M["_start (start.S)<br/>cpsid if"]
        N["Setup 5 exception stacks<br/>FIQ/IRQ/ABT/UND/SVC"]
        O["Zero BSS<br/>_bss_start to _bss_end"]
        P["bl kmain"]
        Q["kmain()<br/>uart_init() - banner"]
        R(["Kernel running"])
    end

    A --> B --> C --> D --> E
    E --> F --> G --> H --> I --> J --> K --> L
    L -->|"SPL to Kernel handoff"| M
    M --> N --> O --> P --> Q --> R
